# ============================================================================
# .env.example — Modelo de variáveis de ambiente
#
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local — ele já está no .gitignore.
# ============================================================================

# ----------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# ----------------------------------------------------------------------------
# Segredo usado para assinar os JWT. Gere com:
#   openssl rand -base64 32
# (ou https://generate-secret.vercel.app/32)
AUTH_SECRET=

# URL pública da aplicação.
# Em desenvolvimento: http://localhost:3000
# Em produção (Vercel): deixe em branco — o runtime usa VERCEL_URL automaticamente.
AUTH_URL=http://localhost:3000

# Confiar no proxy (necessário em Vercel / ambientes atrás de proxy reverso)
AUTH_TRUST_HOST=true

# ----------------------------------------------------------------------------
# Google OAuth 2.0
# ----------------------------------------------------------------------------
# Criar credenciais em:
#   https://console.cloud.google.com/apis/credentials
#
# 1. Crie um projeto (ou selecione um existente).
# 2. APIs & Services → OAuth consent screen → configurar (External, publish).
# 3. APIs & Services → Credentials → Create Credentials → OAuth client ID
#    - Application type: Web application
#    - Authorized JavaScript origins:
#        http://localhost:3000
#        https://SEU-DOMINIO.vercel.app
#    - Authorized redirect URIs:
#        http://localhost:3000/api/auth/callback/google
#        https://SEU-DOMINIO.vercel.app/api/auth/callback/google
# ----------------------------------------------------------------------------
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ----------------------------------------------------------------------------
# Neon Postgres
# ----------------------------------------------------------------------------
# Setup rápido (recomendado):
#   npx neonctl@latest init
# O CLI autentica no browser, cria o projeto e grava DATABASE_URL no .env.
#
# Alternativa: Neon Console → seu projeto → Connection Details →
#   "Pooled connection" → copiar URL com ?sslmode=require
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
